# Repo policy: track ONLY control-py/, control-board-esp32-tcp.yaml, and circuitpy/
# Ignore everything else by default.
*
!.gitignore
!control-board-esp32-tcp.yaml
!control-py/
!control-py/**
!circuitpy/
!circuitpy/**

# Extra safety ignores (redundant with * but kept for clarity)
/.esphome/
/secrets.yaml
/control-py/secrets.yaml
/control-py/.esphome/
__pycache__/
*.pyc
