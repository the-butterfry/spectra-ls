# Description: Top-level ignore rules for Home Assistant monorepo.
# Version: 2026.04.19.1
# Last updated: 2026-04-19

# Secrets / credentials
secrets.yaml
secrets/
**/secrets.yaml
**/.env

# HA runtime state and DB artifacts
.storage/
*.db
*.db-shm
*.db-wal
home-assistant.log*
.ha_run.lock
.HA_VERSION
.shopping_list.json
.arylic_hw_status_cache.json
ip_bans.yaml
known_devices.yaml
lovelace_corrupt_latest.json

# OS/editor/cache noise
.cache/
.vscode/
.Trash-*/
.fseventsd/
__pycache__/
*.pyc

# Temporary/backup snapshots
_backup_*/
esphome_repo_src/
.worktrees/
test.txt

# Archived project trees (local-only; do not sync to GitHub)
esphome/control-py/previous/
esphome/spectra_ls_system/previous/

# Local secret variants
spectra_ls_secrets.yaml
spectra_ls_primary_tcp_host.yaml
spectra_ls_room_tcp_host.yaml

# Non-spectra HA root files (out of repo scope)
configuration.yaml
automations.yaml
scripts.yaml
scenes.yaml
blueprints/
custom_components/

# Keep canonical sources tracked
!.github/
!.github/**
!docs/
!docs/**
!packages/
!packages/**
!esphome/
!esphome/**

# Local AC package kept outside Spectra tracked scope
packages/dst_tuya_ac.yaml

# Re-ignore archived previous folders after broad re-include rules above
esphome/control-py/previous/**
esphome/spectra_ls_system/previous/**

# Guardrail: prevent accidental reintroduction of split package YAML fragments
# under ma_control_hub (only .inc files are valid in that folder).
packages/ma_control_hub/*.yaml
!packages/ma_control_hub/*.inc
