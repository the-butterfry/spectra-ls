{% set verdict = 'PASS' if advisory_only_gap or (score >= 9 and scheduler_ready) else ('WARN' if score >= 7 else 'FAIL') %}
{% set score_percent = ((score | int(0)) * 10) %}
{% set score_bar_len = 16 %}
{% set score_fill = (((score | int(0)) * score_bar_len) / 10) | round(0, 'floor') | int %}
{% set score_empty = score_bar_len - score_fill %}
{% set score_bar = ('#' * score_fill) ~ ('-' * score_empty) %}
{% set target_short = (selected_target.split('.')[-1] if selected_target not in invalid and '.' in selected_target else (selected_target if selected_target not in invalid else 'none')) %}
{% set route_short = (route_decision if route_decision not in invalid else 'missing') %}
{% set host_short = (runtime_control_host if runtime_control_host not in invalid else (top_candidate.host if top_candidate is mapping and top_candidate.host is defined and top_candidate.host not in invalid else 'none')) %}
{% set next_hint = 'WAIT_MA' if (scheduler_waiting_for_ma_boot or bridge_waiting_for_ma_boot) else ('FIX_HOST' if (esp_handoff_status in ['pending_refresh','no_host']) else ('RUN_BRIDGE' if (metadata_bridge_validation.verdict is defined and metadata_bridge_validation.verdict != 'PASS') else ('READY' if (validation_verdict == 'PASS' and scheduler_ready and bridge_ready and selected_in_options) else 'CHECK_WARNS'))) %}

{% set control_host_blocker = 'NONE' %}
{% set control_host_blocker_reason = 'ESP control host path is healthy for this snapshot' %}
{% if scheduler_waiting_for_ma_boot or bridge_waiting_for_ma_boot %}
  {% set control_host_blocker = 'WAITING_FOR_MA_BOOT' %}
  {% set control_host_blocker_reason = 'Music Assistant startup surfaces are not fully ready yet' %}
{% elif esp_handoff_status in ['pending_refresh', 'no_host'] %}
  {% if authority_mode != 'component' and helper_state not in invalid and selected_target not in invalid and helper_state != selected_target %}
    {% set control_host_blocker = 'LEGACY_AUTHORITY_TARGET_MISMATCH' %}
    {% set control_host_blocker_reason = 'Authority is legacy and helper-selected target differs from scheduler-selected target' %}
  {% elif helper_state in invalid %}
    {% set control_host_blocker = 'HELPER_TARGET_UNRESOLVED' %}
    {% set control_host_blocker_reason = 'input_select.ma_active_target is unresolved, so host handoff cannot bind a target' %}
  {% elif runtime_control_host in invalid and runtime_control_hosts in invalid %}
    {% set control_host_blocker = 'CONTROL_HOST_UNRESOLVED' %}
    {% set control_host_blocker_reason = 'sensor.ma_control_host and sensor.ma_control_hosts are unresolved' %}
  {% else %}
    {% set control_host_blocker = 'ESP_HANDOFF_NOT_READY' %}
    {% set control_host_blocker_reason = 'ESP handoff status is not ready; host propagation still pending' %}
  {% endif %}
{% endif %}

