# Description: Example ESPHome secrets template (no real credentials).
# Version: 2026.04.17.1
# Last updated: 2026-04-17

# Wi-Fi
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Optional IoT profile keys
wifi_ssid_iot: "YOUR_IOT_WIFI_SSID"
wifi_password_iot: "YOUR_IOT_WIFI_PASSWORD"
esphome_wifi_ssid_iot: "YOUR_ESPHOME_IOT_WIFI_SSID"
esphome_wifi_password_iot: "YOUR_ESPHOME_IOT_WIFI_PASSWORD"

# Plex (optional)
plex_token: "YOUR_PLEX_TOKEN"
plex_sessions_url: "http://YOUR_PLEX_HOST:32400/status/sessions?X-Plex-Token=YOUR_PLEX_TOKEN"

# Music Assistant / Spectra LS (optional)
ma_ll_token: "Bearer YOUR_MA_LONG_LIVED_TOKEN"
ma_server_url: "http://YOUR_MA_HOST:8095"